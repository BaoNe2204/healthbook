<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- Top Action Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:layout_alignParentTop="true">
        
        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:padding="16dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@android:color/white" />
            
        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chọn Chọn dịch vụ"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="16dp">
            
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Hỗ trợ"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Breadcrumb Area -->
    <HorizontalScrollView
        android:id="@+id/breadcrumbScroll"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/topBar"
        android:background="@android:color/white"
        android:scrollbars="none">
        
        <LinearLayout
            android:id="@+id/breadcrumbContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            
            <!-- Items will be populated programmatically -->
            
        </LinearLayout>
    </HorizontalScrollView>
    
    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_below="@id/breadcrumbScroll"
        android:background="#E0E0E0" />

    <!-- Bottom Fixed Button Area (Only for Step 5) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đã hoàn thành các thông tin đặt khám, nhấn 'Tiếp tục' để xác nhận."
            android:textSize="12sp"
            android:textColor="#424242"/>
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="#0B66E4"
            android:text="Tiếp tục ->"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/divider1"
        android:layout_above="@id/bottomBar">
        
        <!-- STEP 1: Chọn dịch vụ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_border_rounded_grey"
                android:hint="Tìm kiếm chọn dịch vụ"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:textSize="14sp"/>
            
            <RelativeLayout
                android:id="@+id/btnOptSpecialty"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_border_rounded_white_elevation"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Chuyên khoa"
                    android:textColor="#212121"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Chọn"
                    android:textColor="#1976D2"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btnOptPackage"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_border_rounded_white_elevation"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Gói khám"
                    android:textColor="#212121"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Chọn"
                    android:textColor="#1976D2"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- STEP 2: Chọn Chuyên khoa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_border_rounded_grey"
                android:hint="Tìm kiếm chuyên khoa"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:textSize="14sp"/>
                
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="16dp">
                <LinearLayout
                    android:id="@+id/listSpecialtiesStep2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Items populated dynamically -->
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>

        <!-- STEP 3: Chọn Ngày Khám -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_border_rounded_white_elevation"
                android:orientation="vertical"
                android:padding="16dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentStart="true"
                        android:src="@android:drawable/arrow_down_float"
                        android:rotation="90"
                        app:tint="#757575"
                        android:padding="4dp"/>
                    <TextView
                        android:id="@+id/tvMonthYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="Tháng 07 / 2026"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <ImageView
                        android:id="@+id/btnNextMonth"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:src="@android:drawable/arrow_down_float"
                        android:rotation="270"
                        app:tint="#757575"
                        android:padding="4dp"/>
                </RelativeLayout>
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T2" android:textSize="12sp" android:textColor="#424242"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T3" android:textSize="12sp" android:textColor="#424242"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T4" android:textSize="12sp" android:textColor="#424242"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T5" android:textSize="12sp" android:textColor="#424242"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T6" android:textSize="12sp" android:textColor="#424242"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T7" android:textSize="12sp" android:textColor="#1976D2"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="CN" android:textSize="12sp" android:textColor="#D32F2F"/>
                </LinearLayout>
                
                <GridLayout
                    android:id="@+id/gridCalendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="7"
                    android:layout_marginTop="8dp">
                    <!-- Days populated dynamically -->
                </GridLayout>
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <!-- Legend -->
                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#1976D2" android:layout_gravity="center_vertical"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Ngày chọn" android:textSize="12sp"/>
                    
                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#212121" android:layout_marginStart="16dp" android:layout_gravity="center_vertical"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Ngày đặt khám" android:textSize="12sp"/>
                    
                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="#FF9800" android:layout_marginStart="16dp" android:layout_gravity="center_vertical"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Ngày lịch đầy" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_info_details" app:tint="#757575"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Chọn một ngày để đặt khám" android:textColor="#757575" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- STEP 4: Chọn Giờ Khám -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_border_rounded_white_elevation"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <!-- Sáng -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_day" app:tint="#FFB300"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Buổi sáng" android:textColor="#212121" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <GridLayout
                        android:id="@+id/gridTimeMorning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:layout_marginTop="12dp">
                    </GridLayout>
                    
                    <!-- Chiều -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="16dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_info_details" app:tint="#64B5F6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Buổi chiều" android:textColor="#212121" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <GridLayout
                        android:id="@+id/gridTimeAfternoon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:layout_marginTop="12dp">
                    </GridLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/ic_menu_info_details" app:tint="#757575"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Chọn một khung giờ để đặt" android:textColor="#757575" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
        
        <!-- STEP 5: Chọn Bệnh Nhân -->
        <LinearLayout
            android:id="@+id/patientProfilesContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn một hồ sơ trong danh sách hoặc\ntạo mới hồ sơ người bệnh"
                    android:textColor="#424242"
                    android:textSize="13sp"
                    android:layout_centerVertical="true"/>
                <Button
                    android:id="@+id/btnCreateNewProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:backgroundTint="#1976D2"
                    android:text="Tạo mới"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp"
                    android:drawableStart="@android:drawable/ic_input_add"
                    android:drawableTint="@android:color/white"/>
            </RelativeLayout>
            
            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_border_rounded_grey"
                android:hint="Tìm hồ sơ trong danh sách"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:textSize="14sp"/>
                
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_border_rounded_white_elevation"
                android:padding="16dp">
                <!-- Blue border for active item -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignTop="@id/patientAvatar"
                    android:layout_alignBottom="@id/btnSelectPatient"
                    android:background="@drawable/bg_border_rounded_grey" />
                
                <ImageView
                    android:id="@+id/patientAvatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@android:drawable/sym_def_app_icon"/>
                <TextView
                    android:id="@+id/patientTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/patientAvatar"
                    android:layout_alignStart="@id/patientAvatar"
                    android:layout_alignEnd="@id/patientAvatar"
                    android:layout_marginTop="4dp"
                    android:background="#1976D2"
                    android:text="Tôi"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/patientAvatar"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvPatientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Hải Đăng"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvPatientDobGender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎂 08/04/2006 - Nam"
                        android:textColor="#424242"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>
                    <TextView
                        android:id="@+id/tvPatientPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 0346 031 953"
                        android:textColor="#424242"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:background="#1976D2"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="ĐANG CHỌN"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
                
                <TextView
                    android:id="@+id/btnViewPatientDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/patientTag"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_chip_grey"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="Xem chi tiết"
                    android:textColor="#212121"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/btnSelectPatient"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/patientTag"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="16dp"
                    android:background="#E3F2FD"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="8dp"
                    android:text="Chọn"
                    android:textColor="#1976D2"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </RelativeLayout>
        </LinearLayout>
    </ViewFlipper>
</RelativeLayout>
