<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Top Action Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:layout_alignParentTop="true">
        
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@android:color/white" />
            
        <TextView
            android:id="@+id/tvTopTitle"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Phòng khám SIM M"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="16dp">
            
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/btn_star"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp"
                android:text="Lưu lại"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#80FFFFFF"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Hỗ trợ"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Bottom Fixed Button Area -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:padding="16dp">
        <Button
            android:id="@+id/btnBook"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#0B66E4"
            android:text="Đặt khám"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />
    </LinearLayout>
    
    <View
        android:id="@+id/shadowBottom"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_above="@id/bottomBar"
        android:background="@drawable/shadow_gradient_up" />

    <!-- Main Scroll Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomBar"
        android:layout_below="@id/topBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">
            
            <!-- Logo and Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="@android:color/white">
                <ImageView
                    android:id="@+id/ivClinicLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@mipmap/ic_launcher_round" />
                <TextView
                    android:id="@+id/tvClinicName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Phòng khám SIM Medical Center Tân Phú"
                    android:textColor="#212121"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Address Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_chip_grey"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvClinicAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Toà nhà Richstar 2 - RS5,\n239-241 đường Hòa Bình, P. Hiệp Tân, Q.Tân Phú, TP.HCM"
                    android:textColor="#424242"
                    android:textSize="13sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_chip_green"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@android:drawable/ic_dialog_map"
                        app:tint="@android:color/white" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Mở bản đồ"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#F5F5F5" />

            <!-- ACCORDIONS -->
            
            <!-- 1. Giới thiệu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical">
                <RelativeLayout
                    android:id="@+id/headerIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Giới thiệu"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/arrowIntro"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/arrow_up_float"
                        app:tint="#BDBDBD" />
                </RelativeLayout>
                
                <LinearLayout
                    android:id="@+id/contentIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp">
                    <TextView
                        android:id="@+id/tvIntroContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="6dp"
                        android:text="Phòng Khám Đa Khoa SIM Medical Center\n\n• 09/2017: Thành lập dự án phòng khám.\n• 07/2019: Phòng khám nhận giấy phép hoạt động.\n• 08/2019: Khai trương Phòng khám SIM Medical Center.\n• Chuyên Khoa: Nội Khoa, Ngoại khoa, Sản - Phụ Khoa, Nhi Khoa, Bác sĩ gia đình, Tai mũi họng, Xét nghiệm, Chẩn đoán hình ảnh, Tiêm chủng.\n\nTầm nhìn và sứ mệnh:\n• Trở thành một trung tâm y tế - một điểm đến chăm sóc sức khỏe chuyên nghiệp,..."
                        android:textColor="#424242"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Xem thêm"
                        android:textColor="#757575"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#F5F5F5" />

            <!-- 2. Chuyên khoa -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical">
                <RelativeLayout
                    android:id="@+id/headerSpecialties"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Chuyên khoa"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/arrowSpecialties"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/arrow_up_float"
                        app:tint="#BDBDBD" />
                </RelativeLayout>
                
                <LinearLayout
                    android:id="@+id/contentSpecialties"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_border_rounded_grey">
                    <!-- We will populate list items programmatically or statically here -->
                    <LinearLayout android:id="@+id/listSpecialties" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="4dp" android:background="#F5F5F5" />

            <!-- 3. Chuyên khám -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical">
                <RelativeLayout
                    android:id="@+id/headerServices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Chuyên khám"
                        android:textColor="#212121"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/arrowServices"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/arrow_up_float"
                        app:tint="#BDBDBD" />
                </RelativeLayout>
                
                <LinearLayout
                    android:id="@+id/contentServices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_border_rounded_grey">
                    <!-- List items -->
                    <LinearLayout android:id="@+id/listServices" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp" android:background="#F5F5F5" />

            <!-- Menu Bottom Options -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_border_rounded_white_elevation"
                android:orientation="vertical">
                
                <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="Các câu hỏi thường gặp" android:textColor="#424242" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/arrow_up_float" android:rotation="90" app:tint="#BDBDBD" />
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#EEEEEE" />
                
                <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="Quy trình thanh toán và hoàn/huỷ" android:textColor="#424242" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/arrow_up_float" android:rotation="90" app:tint="#BDBDBD" />
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="#EEEEEE" />
                
                <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp" android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="Phản hồi thông tin" android:textColor="#424242" android:textSize="14sp" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/arrow_up_float" android:rotation="90" app:tint="#BDBDBD" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Back to top -->
            <LinearLayout
                android:id="@+id/btnBackToTop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="12dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/arrow_up_float"
                    app:tint="#9E9E9E" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="LÊN ĐẦU TRANG"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
